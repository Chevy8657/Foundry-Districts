from fastapi import APIRouter

router = APIRouter()

@router.get("/math/divide-numbers")
def divide_numbers(a: float, b: float):

    if b == 0:
        return {
            "a": a,
            "b": b,
            "error": "division by zero"
        }

    return {
        "a": a,
        "b": b,
        "result": a / b
    }
